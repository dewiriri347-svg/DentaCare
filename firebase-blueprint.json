{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "name": {
          "type": "string",
          "description": "Full name of the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address"
        },
        "role": {
          "type": "string",
          "enum": ["Admin", "Dokter Gigi", "Terapis Gigi dan Mulut", "Dosen", "Pasien"],
          "description": "Role of the user"
        }
      },
      "required": ["uid", "name", "email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles including their roles"
    }
  }
}
